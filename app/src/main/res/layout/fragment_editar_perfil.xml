<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gris"
    android:paddingBottom="50sp"
    tools:context=".ui.main.perfil.EditarPerfilFragment">



    <LinearLayout
        android:layout_width="match_parent"
        android:gravity="center"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/logo_login"
            android:layout_width="86dp"
            android:layout_height="114dp"
            app:srcCompat="@drawable/logo_app" />

        <TextView
            android:id="@+id/nombreApp_Login"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:fontFamily="@font/tiro_devanagari_hindi"
            android:text="@string/app_name"
            android:textAlignment="textStart"
            android:textColor="@color/rojo"
            android:textSize="30sp"
            android:textStyle="bold"
            />
    </LinearLayout>

    <TextView
        android:id="@+id/description_login"
        android:layout_width="271dp"
        android:layout_height="45dp"
        android:layout_marginTop="30dp"
        android:text="@string/tv_editar_perfil"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textSize="25sp"
        android:textStyle="bold|italic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/logo_login" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:layout_marginTop="20sp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:orientation="vertical"
                android:gravity="fill_vertical"
                android:layout_height="wrap_content">


                <EditText
                    android:id="@+id/input_names"
                    android:layout_width="280dp"
                    android:layout_height="48dp"
                    android:layout_marginBottom="15sp"
                    android:background="@drawable/style_input"
                    android:paddingStart="15dp"
                    android:fontFamily="@font/tiro_devanagari_hindi"
                    android:paddingEnd="15dp"
                    android:ems="10"
                    android:hint="@string/hint_name_input"
                    android:inputType="text"
                    android:textColor="@color/black"
                    android:textColorHint="@color/hint_color"
                    />
                <EditText
                    android:id="@+id/input_lastName"
                    android:layout_width="280dp"
                    android:layout_height="48dp"
                    android:fontFamily="@font/tiro_devanagari_hindi"

                    android:layout_marginBottom="15sp"
                    android:background="@drawable/style_input"
                    android:paddingStart="15dp"
                    android:paddingEnd="15dp"
                    android:ems="10"
                    android:hint="@string/hint_lastname_input"
                    android:inputType="text"
                    android:textColor="@color/black"
                    android:textColorHint="@color/hint_color"
                    />

                <EditText
                    android:id="@+id/input_email_register"
                    android:layout_width="280dp"
                    android:layout_height="48dp"
                    android:layout_marginBottom="15sp"
                    android:background="@drawable/style_input"
                    android:paddingStart="15dp"
                    android:fontFamily="@font/tiro_devanagari_hindi"

                    android:paddingEnd="15dp"
                    android:ems="10"
                    android:hint="@string/hint_email_register"
                    android:textColor="@color/black"
                    android:textColorHint="@color/hint_color"
                    android:inputType="textEmailAddress" />

                <EditText
                    android:id="@+id/input_password_register"
                    android:layout_width="280dp"
                    android:fontFamily="@font/tiro_devanagari_hindi"

                    android:layout_height="48dp"
                    android:layout_marginBottom="15sp"
                    android:background="@drawable/style_input"
                    android:paddingStart="15dp"
                    android:hint="@string/hint_password_input"
                    android:textColor="@color/black"
                    android:paddingEnd="15dp"
                    android:ems="10"
                    android:inputType="textPassword"
                    />
                <EditText
                    android:id="@+id/input_confirm_password_register"
                    android:layout_width="280dp"
                    android:layout_height="48dp"
                    android:background="@drawable/style_input"
                    android:paddingStart="15dp"
                    android:fontFamily="@font/tiro_devanagari_hindi"

                    android:hint="@string/hint_confirm_password_input"
                    android:textColor="@color/black"
                    android:paddingEnd="15dp"
                    android:ems="10"
                    android:inputType="textPassword"
                    />




            </LinearLayout>

        </LinearLayout>
    </ScrollView>
    <Button
        android:id="@+id/button_register"
        android:layout_width="217dp"
        android:layout_height="58dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/rojo"
        android:fontFamily="@font/tiro_devanagari_hindi"
        android:text="@string/tv_actualizar"
        android:textColor="@color/white"
        android:textSize="25sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/input_password"
        app:strokeColor="@color/white"
        app:strokeWidth="3dp" />



</LinearLayout>